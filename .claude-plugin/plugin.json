{
  "name": "ai-architect",
  "description": "Autonomous software engineering pipeline for Claude Code — 11 stages, 49 MCP tools, 64 verification rules. Skills define WHAT, tools define HOW, hooks enforce constraints.",
  "version": "0.1.0",
  "author": {
    "name": "Clement Deust",
    "email": "admin@ai-architect.tools"
  },
  "homepage": "https://github.com/cdeust/ai-architect-mcp",
  "repository": "https://github.com/cdeust/ai-architect-mcp",
  "license": "MIT",
  "keywords": ["mcp", "ai-architect", "verification", "prd", "autonomous-engineering", "claude-code", "anthropic"],
  "mcpServers": {
    "ai-architect": {
      "command": "uvx",
      "args": ["--python", "3.12", "--from", "ai-automated-pipeline", "ai_architect_mcp"]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/stop.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
