{
  "name": "ai-codebase-intelligence",
  "version": "0.1.0",
  "description": "Language-agnostic codebase intelligence — index, search, and analyze code across 13 languages",
  "author": "AI Architect",
  "homepage": "https://github.com/ai-architect-tools/ai-codebase-intelligence",
  "license": "MIT",
  "capabilities": {
    "mcp_server": true,
    "hooks": true,
    "skills": true
  },
  "mcp": {
    "command": "python3",
    "args": ["-m", "ai_codebase_intelligence.server"],
    "env": {
      "PYTHONPATH": "src"
    }
  },
  "hooks": {
    "config": "hooks/hooks.json"
  },
  "skills": [
    "skills/exploring/SKILL.md",
    "skills/debugging/SKILL.md",
    "skills/impact-analysis/SKILL.md",
    "skills/pr-review/SKILL.md",
    "skills/refactoring/SKILL.md",
    "skills/cli/SKILL.md",
    "skills/guide/SKILL.md"
  ],
  "requirements": {
    "python": ">=3.11",
    "packages": [
      "mcp>=1.0",
      "tree-sitter>=0.22",
      "tree-sitter-languages>=1.10",
      "kuzu>=0.4",
      "pydantic>=2.0",
      "leidenalg>=0.10",
      "python-igraph>=0.11",
      "gitpython>=3.1",
      "typer>=0.12"
    ]
  }
}
